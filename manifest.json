{
  "manifest_version": 3,
  "name": "Maps AI Review Generator",
  "version": "1.0",
  "description": "Extracts Google Maps place info and generates AI reviews and image prompts using Gemini.",
  "permissions": [
    "activeTab",
    "scripting",
    "storage",
    "downloads",
    "sidePanel"
  ],
  "host_permissions": [
    "https://www.google.com/maps/*",
    "https://generativelanguage.googleapis.com/*",
    "https://image.pollinations.ai/*",
    "https://api.imgbb.com/*"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "side_panel": {
    "default_path": "sidepanel.html"
  },
  "action": {
    "default_title": "Open Maps AI Review"
  }
}
