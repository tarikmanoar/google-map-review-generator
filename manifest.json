{
  "manifest_version": 3,
  "name": "Maps AI Review Generator",
  "version": "1.0",
  "description": "Extracts Google Maps place info and generates AI reviews and image prompts using Gemini.",
  "permissions": [
    "activeTab",
    "scripting",
    "storage",
    "downloads"
  ],
  "host_permissions": [
    "https://www.google.com/maps/*",
    "https://generativelanguage.googleapis.com/*",
    "https://image.pollinations.ai/*",
    "https://api.imgbb.com/*"
  ],
  "action": {
    "default_popup": "popup.html",
    "default_title": "Generate AI Review"
  }
}